# ─────────────────────────────────────────────────────────────
# Phober — corner-stone env file
#
# Everything else lives in docker-compose.*.yml.
# Copy to .env and fill in real values for your machine.
# ─────────────────────────────────────────────────────────────

# ── App ──
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Baku
LOG_LEVEL=debug
TELESCOPE_ENABLED=true

# ── Laravel APP_KEY per service (generate with `php artisan key:generate --show`) ──
APP_KEY_ADMINPANEL=base64:10GvWo3QVZLvODVr0rKxufpyI2rUVmLqbWv6dfEWs4U=
APP_KEY_AUTH_SERVER=base64:10GvWo3QVZLvODVr0rKxufpyI2rUVmLqbWv6dfEWs4U=
APP_KEY_CONFIG_SERVER=base64:10GvWo3QVZLvODVr0rKxufpyI2rUVmLqbWv6dfEWs4U=
APP_KEY_CRM_SERVICE=base64:10GvWo3QVZLvODVr0rKxufpyI2rUVmLqbWv6dfEWs4U=
APP_KEY_DEVICE_SERVICE=base64:10GvWo3QVZLvODVr0rKxufpyI2rUVmLqbWv6dfEWs4U=
APP_KEY_NOTIFICATION_SERVER=base64:10GvWo3QVZLvODVr0rKxufpyI2rUVmLqbWv6dfEWs4U=
APP_KEY_STAFF_SERVICE=base64:10GvWo3QVZLvODVr0rKxufpyI2rUVmLqbWv6dfEWs4U=
